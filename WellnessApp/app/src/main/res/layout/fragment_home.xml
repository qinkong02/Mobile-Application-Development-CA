<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvGreeting"
            style="@style/TextTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_greeting"
            android:textSize="22sp"
            android:textColor="@color/green_primary"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:id="@+id/cardAiSuggestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_ai_suggestion"
            android:outlineProvider="background"
            android:elevation="3dp"
            android:padding="18dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                style="@style/TextSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_suggestion_title"
                android:textSize="14sp"
                android:textColor="@color/green_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvAiSuggestion"
                style="@style/TextBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/loading_suggestion"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <TextView
            style="@style/TextSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_entry_title"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardQuickEntry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:outlineProvider="background"
                android:elevation="2dp"
                android:padding="18dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_circle_teal_light"
                    android:src="@drawable/ic_add"
                    app:tint="@color/green_mid"
                    android:contentDescription="@null" />

                <TextView
                    style="@style/TextBody"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/quick_entry_record"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardQuickChat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:outlineProvider="background"
                android:elevation="2dp"
                android:padding="18dp"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:background="@drawable/bg_circle_teal_100"
                    android:src="@drawable/ic_chat"
                    app:tint="@color/green_mid"
                    android:contentDescription="@null" />

                <TextView
                    style="@style/TextBody"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/quick_entry_chat"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>