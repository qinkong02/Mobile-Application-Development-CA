<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/btnBack"
            style="@style/TextTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="18dp"
            app:drawableStartCompat="@drawable/ic_back"
            app:drawableTint="@color/green_primary"
            android:drawablePadding="10dp"
            android:text="@string/add_record_title"
            android:textSize="16sp"
            android:textColor="@color/green_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView style="@style/FieldLabel" android:text="@string/record_type_label" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/chipSleep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                    android:minHeight="48dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/bg_pill_sleep_accent"
                    android:text="@string/record_type_sleep"
                    android:textSize="12sp"
                    android:textColor="@color/green_primary"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipExercise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                    android:minHeight="48dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/bg_pill_outline"
                    android:text="@string/record_type_exercise"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvExerciseTypeLabel"
                style="@style/FieldLabel"
                android:text="@string/exercise_type_label"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/scrollExerciseType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipExerciseRunning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_pill_exercise_accent"
                        android:text="@string/exercise_type_running"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipExerciseYoga"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_pill_outline"
                        android:text="@string/exercise_type_yoga"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipExerciseSwimming"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_pill_outline"
                        android:text="@string/exercise_type_swimming"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipExerciseGym"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_pill_outline"
                        android:text="@string/exercise_type_gym"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipExerciseOther"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_pill_outline"
                        android:text="@string/exercise_type_other"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvValueLabel"
                style="@style/FieldLabel"
                android:text="@string/sleep_duration_label" />
            <EditText
                android:id="@+id/etValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="@drawable/bg_input"
                android:hint="@string/sleep_duration_hint"
                android:inputType="numberDecimal"
                android:importantForAutofill="no"
                android:layout_marginBottom="12dp" />

            <TextView style="@style/FieldLabel" android:text="@string/date_label" />
            <EditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="@drawable/bg_input"
                android:hint="@string/date_hint"
                android:inputType="date"
                android:importantForAutofill="no"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="12dp" />

            <TextView style="@style/FieldLabel" android:text="@string/note_label" />
            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_input"
                android:hint="@string/note_hint"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:importantForAutofill="no"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_button_primary"
                android:outlineProvider="background"
                android:elevation="3dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.015"
                android:text="@string/save_record"
                android:textColor="@color/white"
                android:textAllCaps="false" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
